<view class="container">
  <!-- Stats -->
  <view class="stats-row">
    <view class="stat-card stat-orange"><view class="stat-value">{{stats.total}}</view><view class="stat-label">总投稿</view></view>
    <view class="stat-card stat-blue"><view class="stat-value">{{stats.submitted}}</view><view class="stat-label">审核中</view></view>
    <view class="stat-card stat-green"><view class="stat-value">{{stats.accepted}}</view><view class="stat-label">录用</view></view>
    <view class="stat-card stat-purple"><view class="stat-value">{{stats.revision}}</view><view class="stat-label">修改中</view></view>
  </view>

  <!-- Add button -->
  <view class="btn btn-primary btn-full mb-24" bindtap="showAddModal">➕ 添加投稿记录</view>

  <!-- List -->
  <view wx:if="{{subs.length === 0}}" class="empty">
    <view class="empty-icon">📄</view><text>暂无投稿记录</text>
  </view>
  <view wx:for="{{subs}}" wx:key="id" class="sub-item status-{{item.status}}">
    <view class="flex items-center justify-between">
      <view style="flex:1">
        <view class="sub-title">{{item.title}}</view>
        <view class="flex gap-12 mt-8">
          <text class="text-sm text-muted">🏛 {{item.venue}}</text>
          <text wx:if="{{item.submitDate}}" class="text-sm text-muted">📅 {{item.submitDate}}</text>
        </view>
      </view>
      <view class="flex flex-col gap-8 items-center">
        <view class="status status-{{item.status}}">{{item.statusLabel}}</view>
        <view class="flex gap-8">
          <view class="btn btn-ghost btn-sm" bindtap="editSub" data-id="{{item.id}}">✏️</view>
          <view class="btn btn-danger btn-sm" bindtap="delSub" data-id="{{item.id}}">🗑</view>
        </view>
      </view>
    </view>
    <view wx:if="{{item.notes}}" class="sub-notes">{{item.notes}}</view>
  </view>

  <!-- Add/Edit Modal -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal-box" wx:if="{{showModal}}">
    <view class="modal-title">{{editId ? '编辑投稿' : '添加投稿'}}</view>
    <view class="form-item">
      <text class="label">论文标题</text>
      <input class="input" placeholder="论文标题…" value="{{form.title}}" bindinput="onInput" data-field="title"/>
    </view>
    <view class="form-item">
      <text class="label">会议/期刊</text>
      <input class="input" placeholder="如：NeurIPS 2026" value="{{form.venue}}" bindinput="onInput" data-field="venue"/>
    </view>
    <view class="form-row">
      <view class="form-item">
        <text class="label">状态</text>
        <picker range="{{statusLabels}}" value="{{form.statusIdx}}" bindchange="onStatusChange">
          <view class="picker-wrap">{{statusLabels[form.statusIdx]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">投稿日期</text>
        <picker mode="date" value="{{form.submitDate}}" bindchange="onSubmitDateChange">
          <view class="picker-wrap">{{form.submitDate || '选择日期'}}</view>
        </picker>
      </view>
    </view>
    <view class="form-item">
      <text class="label">备注</text>
      <textarea class="textarea" placeholder="OpenReview链接、分数等…" value="{{form.notes}}" bindinput="onInput" data-field="notes"/>
    </view>
    <view class="flex gap-16 mt-24">
      <view class="btn btn-ghost flex-1" bindtap="closeModal">取消</view>
      <view class="btn btn-primary flex-1" bindtap="saveSub">保存</view>
    </view>
  </view>
</view>
