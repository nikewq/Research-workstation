.setup-page {
  min-height: 100vh; background: #0d1117;
  padding: 80rpx 40rpx 60rpx; display: flex; flex-direction: column;
}
.setup-header { text-align: center; margin-bottom: 48rpx; }
.setup-logo { font-size: 100rpx; }
.setup-app-name { font-size: 44rpx; font-weight: 700; color: #7c3aed; margin-top: 12rpx; }
.setup-tagline { font-size: 26rpx; color: #8b949e; margin-top: 8rpx; }
.progress-bar { display: flex; gap: 12rpx; margin-bottom: 8rpx; }
.prog-dot { flex: 1; height: 6rpx; border-radius: 3rpx; background: #30363d; }
.prog-dot.done { background: #7c3aed; }
.step-label { font-size: 22rpx; color: #8b949e; margin-bottom: 32rpx; }
.step-box { flex: 1; }

/* 全宽输入框 */
.full-input {
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  min-height: 88rpx;
  line-height: 1.4;
}

/* 说明提示 */
.info-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: rgba(124,58,237,.08);
  border: 1rpx solid rgba(124,58,237,.3);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}
.info-tip-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.info-tip-text { font-size: 24rpx; color: #a78bfa; line-height: 1.6; }
.step-title { font-size: 36rpx; font-weight: 700; margin-bottom: 8rpx; }
.step-desc { font-size: 26rpx; color: #8b949e; margin-bottom: 24rpx; }
.step-nav { display: flex; margin-top: 40rpx; gap: 16rpx; }
.proj-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.proj-color { width: 28rpx; height: 28rpx; border-radius: 50%; flex-shrink: 0; }
.del-btn { padding: 8rpx 16rpx; color: #ef4444; font-size: 32rpx; }
.add-proj-row { display: flex; flex-direction: column; gap: 12rpx; margin-top: 8rpx; }
.color-picker-row { display: flex; gap: 12rpx; }
.color-dot { width: 40rpx; height: 40rpx; border-radius: 50%; border: 3rpx solid transparent; }
.color-dot.selected { border-color: #e6edf3; }
.habit-option {
  display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 24rpx; background: #1c2128;
  border-radius: 14rpx; margin-bottom: 12rpx;
  border: 2rpx solid transparent;
}
.habit-option.selected { border-color: #7c3aed; background: rgba(124,58,237,.1); }
.done-icon { font-size: 100rpx; text-align: center; margin: 40rpx 0 24rpx; }
.summary-card { background: #161b22; border: 1rpx solid #30363d; border-radius: 16rpx; padding: 24rpx; margin-top: 32rpx; }
.summary-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #30363d; font-size: 28rpx; }
.summary-row:last-child { border-bottom: none; }
