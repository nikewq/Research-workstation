.profile-card { background: #161b22; border: 1rpx solid #30363d; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; display: flex; align-items: center; gap: 24rpx; }
.avatar { font-size: 80rpx; }
.profile-info { flex: 1; }
.profile-name { font-size: 36rpx; font-weight: 700; }
.profile-field { font-size: 26rpx; color: #7c3aed; margin-top: 4rpx; }
.phd-badge { text-align: center; background: rgba(124,58,237,.1); border-radius: 16rpx; padding: 16rpx 24rpx; }
.phd-num { font-size: 44rpx; font-weight: 700; color: #7c3aed; }
.phd-lbl { font-size: 20rpx; color: #8b949e; }
.menu-item { display: flex; align-items: center; gap: 20rpx; padding: 28rpx 0; border-bottom: 1rpx solid #30363d; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; }
.menu-label { flex: 1; font-size: 30rpx; }
.menu-arrow { color: #8b949e; font-size: 36rpx; }
