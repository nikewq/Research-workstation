.phd-day-badge { text-align: center; background: rgba(124,58,237,.1); border-radius: 16rpx; padding: 16rpx 24rpx; }
.phd-day-num { font-size: 52rpx; font-weight: 700; color: #7c3aed; }
.phd-day-label { font-size: 20rpx; color: #8b949e; }
.checkin-bar { display: flex; align-items: center; gap: 20rpx; }
.clock-text { font-size: 44rpx; font-weight: 700; color: #7c3aed; font-variant-numeric: tabular-nums; }
.ci-status { font-size: 24rpx; color: #8b949e; margin-top: 4rpx; }
.work-time { font-size: 24rpx; color: #059669; font-weight: 600; }
.stats-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.habits-quick { display: flex; flex-wrap: wrap; gap: 12rpx; }
.habit-quick-item {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 20rpx; border-radius: 999rpx;
  background: #1c2128;
}
.habit-quick-item.done { background: rgba(5,150,105,.15); }
