<scroll-view scroll-y class="container">
  <!-- Hello -->
  <view class="flex items-center justify-between mb-24">
    <view>
      <view class="page-title">{{hello}}</view>
      <view class="page-subtitle">{{dateStr}}</view>
    </view>
    <view class="phd-day-badge">
      <view class="phd-day-num">{{phdDay}}</view>
      <view class="phd-day-label">博士第N天</view>
    </view>
  </view>

  <!-- Check-in bar -->
  <view class="card checkin-bar">
    <view class="flex-1">
      <view class="clock-text">{{clock}}</view>
      <view class="ci-status">{{ciStatus}}</view>
    </view>
    <view wx:if="{{!ciDone && !coTime}}" class="btn btn-primary btn-sm" bindtap="handleCheckin">🟢 签到</view>
    <view wx:if="{{ciDone && !coTime}}" class="btn btn-ghost btn-sm" bindtap="handleCheckout">🔴 签出</view>
    <view wx:if="{{coTime}}" class="work-time">{{workTime}}</view>
  </view>

  <!-- Stats row -->
  <view class="stats-row">
    <view class="stat-card stat-purple">
      <view class="stat-value">{{stats.tasks}}</view>
      <view class="stat-label">完成任务</view>
    </view>
    <view class="stat-card stat-green">
      <view class="stat-value">{{stats.pomos}}</view>
      <view class="stat-label">番茄钟</view>
    </view>
    <view class="stat-card stat-orange">
      <view class="stat-value">{{stats.habits}}</view>
      <view class="stat-label">习惯</view>
    </view>
  </view>

  <!-- Today tasks -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">待做任务</view>
      <view class="btn btn-ghost btn-sm" bindtap="goTasks">全部</view>
    </view>
    <view wx:if="{{pendingTasks.length === 0}}" class="empty">
      <view class="empty-icon">✅</view>
      <text>今日任务全部完成！</text>
    </view>
    <view wx:for="{{pendingTasks}}" wx:key="id" class="list-item" bindtap="toggleTask" data-id="{{item.id}}">
      <view class="checkbox {{item.status==='done'?'checked':''}}">{{item.status==='done'?'✓':''}}</view>
      <view class="flex-1">
        <view class="{{item.status==='done'?'line-through text-muted':''}}">{{item.title}}</view>
        <view class="flex gap-8 mt-8">
          <view class="tag" style="background:{{item.projColor}}22;color:{{item.projColor}}">{{item.projName}}</view>
          <view wx:if="{{item.due}}" class="text-xs {{item.overdue?'text-red':'text-muted'}}">📅 {{item.due}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- Habits quick -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">今日习惯</view>
      <view class="btn btn-ghost btn-sm" bindtap="goHabits">打卡</view>
    </view>
    <view wx:if="{{habits.length === 0}}" class="empty">
      <view class="empty-icon">🔥</view><text>还没设置习惯</text>
    </view>
    <view class="habits-quick">
      <view wx:for="{{habits}}" wx:key="id"
        class="habit-quick-item {{item.done?'done':''}}"
        bindtap="toggleHabit" data-id="{{item.id}}">
        <text style="font-size:36rpx">{{item.emoji}}</text>
        <text style="font-size:22rpx;color:{{item.done?'#059669':'#8b949e'}}">{{item.name}}</text>
        <text wx:if="{{item.done}}" style="font-size:22rpx">✅</text>
      </view>
    </view>
  </view>

  <!-- Submissions -->
  <view class="card" wx:if="{{recentSubs.length > 0}}">
    <view class="section-header">
      <view class="section-title">投稿追踪</view>
      <view class="btn btn-ghost btn-sm" bindtap="goSubs">全部</view>
    </view>
    <view wx:for="{{recentSubs}}" wx:key="id" style="padding:12rpx 0;border-bottom:1rpx solid #30363d">
      <view class="flex items-center justify-between">
        <view style="flex:1;font-size:28rpx;font-weight:500">{{item.title}}</view>
        <view class="status status-{{item.status}}">{{item.statusLabel}}</view>
      </view>
      <view class="text-xs text-muted mt-8">{{item.venue}}</view>
    </view>
  </view>
</scroll-view>
