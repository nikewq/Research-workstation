<view class="container">
  <view class="card pomo-card">
    <!-- Task select -->
    <view class="form-item">
      <text class="label">当前任务</text>
      <picker range="{{taskNames}}" value="{{taskIdx}}" bindchange="onTaskChange">
        <view class="picker-wrap">{{taskNames[taskIdx] || '自由专注…'}}</view>
      </picker>
    </view>

    <!-- Timer display -->
    <view class="pomo-display">
      <view class="pomo-time {{isBreak?'break':'work'}}">{{timeStr}}</view>
      <view class="pomo-label">{{label}}</view>
    </view>

    <!-- Round dots -->
    <view class="pomo-dots">
      <view wx:for="{{[1,2,3,4]}}" wx:key="*this"
        class="pomo-dot {{round >= item ? 'done' : ''}}"></view>
    </view>

    <!-- Controls -->
    <view class="flex gap-16" style="justify-content:center;margin-top:24rpx">
      <view class="btn btn-primary" style="min-width:200rpx" bindtap="togglePomo">{{running?'⏸ 暂停':'▶ 开始'}}</view>
      <view class="btn btn-ghost" bindtap="resetPomo">↺ 重置</view>
    </view>

    <!-- Settings -->
    <view class="pomo-settings">
      <view class="pomo-set-item">
        <text class="label">专注 (分钟)</text>
        <input class="input" type="number" value="{{workMin}}" bindinput="onWorkMin"/>
      </view>
      <view class="pomo-set-item">
        <text class="label">休息 (分钟)</text>
        <input class="input" type="number" value="{{breakMin}}" bindinput="onBreakMin"/>
      </view>
    </view>
  </view>

  <!-- Today log -->
  <view class="card">
    <view class="card-title">今日记录 ({{todayPomos.length}} 🍅)</view>
    <view wx:if="{{todayPomos.length === 0}}" class="empty">
      <view class="empty-icon">🍅</view><text>今日暂无记录</text>
    </view>
    <view wx:for="{{todayPomos}}" wx:key="id" class="pomo-log-item">
      <text>🍅 {{item.taskTitle || '自由专注'}}</text>
      <text class="text-muted text-sm">{{item.ts}} · {{item.dur}}min</text>
    </view>
  </view>
</view>
