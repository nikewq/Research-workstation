.filter-row { white-space: nowrap; margin-bottom: 16rpx; }
.filter-chip {
  display: inline-block; padding: 10rpx 24rpx;
  border-radius: 999rpx; font-size: 26rpx; margin-right: 12rpx;
  background: #1c2128; color: #8b949e; border: 1rpx solid #30363d;
}
.filter-chip.active { background: rgba(124,58,237,.15); color: #7c3aed; border-color: #7c3aed; }
.task-count { font-size: 24rpx; color: #8b949e; margin-bottom: 16rpx; }
.task-title { font-size: 28rpx; font-weight: 500; }
.del-btn { font-size: 32rpx; padding: 4rpx 12rpx; color: #8b949e; }
